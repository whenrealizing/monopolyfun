OKX_ONCHAIN_PAY_DEFAULT_ASSET=USDC
OKX_ONCHAIN_PAY_DEFAULT_NETWORK=xlayer
PRIVATE_KEY=

# 收益分配：OpenClaw 正常用户流由系统初始化，用户无需输入链、合约和 token。
MONOPOLYFUN_REVENUE_CHAIN_ID=eip155:56
MONOPOLYFUN_REVENUE_CHAIN_NAME=BSC
MONOPOLYFUN_REVENUE_ASSET=BNB
MONOPOLYFUN_REVENUE_TOKEN_TYPE=native
MONOPOLYFUN_REVENUE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
MONOPOLYFUN_REVENUE_ROUTER_ADDRESS=
MONOPOLYFUN_REVENUE_RPC_EIP155_56=

# Digital inventory encryption
