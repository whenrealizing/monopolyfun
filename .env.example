# Market matching
MARKET_MATCHING_PROVIDER=aliyun_qwen
ALIYUN_QWEN_API_KEY=
ALIYUN_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MARKET_EMBEDDING_MODEL=Qwen3-Embedding-0.6B
