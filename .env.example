MARKET_RERANK_TOP_N=30
MARKET_VECTOR_CANDIDATE_LIMIT=80
MARKET_TEXT_CANDIDATE_LIMIT=80
MARKET_MATCHED_THRESHOLD=0.75
MARKET_REVIEW_THRESHOLD=0.45

