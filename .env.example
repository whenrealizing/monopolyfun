# Web
WEB_HOST_PORT=3000
API_HOST_PORT=8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
API_BASE_URL=http://api:8080

# Postgres
POSTGRES_HOST_PORT=55432
DATABASE_URL=jdbc:postgresql://postgres:5432/monopolyfun
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2
DB_CONNECTION_TIMEOUT_MS=30000
DB_VALIDATION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=300000
DB_MAX_LIFETIME_MS=1800000

# Security
APP_PRODUCTION=false
MONOPOLYFUN_SCHEDULER_ENABLED=false
SESSION_COOKIE_NAME=MONOPOLYFUN_SESSION
SESSION_TTL=30d
CSRF_COOKIE_NAME=MONOPOLYFUN_CSRF
CSRF_HEADER_NAME=X-CSRF-Token
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
WEB_ORIGIN=http://localhost:3000

# Upload provider
UPLOAD_PROVIDER=fake
UPLOAD_BUCKET=monopolyfun-proof-artifacts
UPLOAD_ENDPOINT=
UPLOAD_REGION=auto
UPLOAD_ACCESS_KEY_ID=
UPLOAD_SECRET_ACCESS_KEY=
UPLOAD_BASE_URL=https://r2.example/monopolyfun-proof-artifacts
PUBLIC_BASE_URL=https://r2.example/monopolyfun-proof-artifacts
UPLOAD_PRESIGN_TTL=15m
UPLOAD_MAX_BYTES=10485760

